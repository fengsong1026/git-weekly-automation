#!/usr/bin/env bash
# ============================================================================
# git-weekly-automation setup script
#
# Usage:
#   ./scripts/setup            Install global git hook
#   ./scripts/setup uninstall  Remove global git hook
# ============================================================================

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
HOOKS_DIR="$PROJECT_DIR/hooks"
HOOKS_PATH_ABS="$(cd "$HOOKS_DIR" && pwd)"

# Colors for output
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m' # No Color

ACTION="${1:-install}"
YES_FLAG=false
if [ "$ACTION" = "--yes" ] || [ "$ACTION" = "-y" ]; then
    YES_FLAG=true
    ACTION="${2:-uninstall}"
fi
if [ "${2:-}" = "--yes" ] || [ "${2:-}" = "-y" ]; then
    YES_FLAG=true
fi

# ======================================================================
# Uninstall
# ======================================================================
if [ "$ACTION" = "uninstall" ]; then
    echo "============================================"
    echo "  git-weekly-automation — Uninstall All"
    echo "============================================"
    echo ""

    if [ "$YES_FLAG" = true ]; then
        echo "[*] Non-interactive mode (--yes)"
        echo ""
    fi

    # --- Read registry for authoritative artifact list ---
    REGISTRY_DATA=$(python3 -c "
import sys; sys.path.insert(0, '$SCRIPT_DIR')
from registry import load_registry
import json
reg = load_registry()
entry = reg.get('installations', {}).get('$PROJECT_DIR', {})
print(json.dumps({
    'found': bool(entry),
    'hooks_path_set': entry.get('hooks_path_set', False),
    'original_hooks_path': entry.get('original_hooks_path'),
    'tasks': entry.get('scheduled_tasks', {}),
}, ensure_ascii=False))
" 2>/dev/null || echo '{"found":false,"hooks_path_set":false,"tasks":{}}')

    FOUND=$(echo "$REGISTRY_DATA" | python3 -c "import json,sys; print(json.load(sys.stdin)['found'])")
    HOOKS_SET=$(echo "$REGISTRY_DATA" | python3 -c "import json,sys; print(json.load(sys.stdin)['hooks_path_set'])")
    ORIG_HOOKS=$(echo "$REGISTRY_DATA" | python3 -c "import json,sys; d=json.load(sys.stdin); print(d.get('original_hooks_path') or '')")
    TASK_JSON=$(echo "$REGISTRY_DATA" | python3 -c "import json,sys; print(json.dumps(json.load(sys.stdin)['tasks']))")

    # --- 1. Remove git hook ---
    echo "[1/4] Git global hook..."
    if [ -n "$ORIG_HOOKS" ]; then
        git config --global core.hooksPath "$ORIG_HOOKS" 2>/dev/null || git config --global --unset core.hooksPath 2>/dev/null || true
        echo -e "      ${GREEN}Restored.${NC} hooksPath → $ORIG_HOOKS"
    else
        CURRENT_HOOKS_PATH="$(git config --global core.hooksPath 2>/dev/null || echo "")"
        if [ "$CURRENT_HOOKS_PATH" = "$HOOKS_PATH_ABS" ]; then
            git config --global --unset core.hooksPath
            echo -e "      ${GREEN}Removed.${NC} Git restored to default."
        elif [ -z "$CURRENT_HOOKS_PATH" ]; then
            echo "       No hook configured. Skipped."
        else
            echo -e "      ${YELLOW}HooksPath is $CURRENT_HOOKS_PATH — not ours. Skipped.${NC}"
        fi
    fi

    # --- 2. Clear scheduled tasks (registry-aware) ---
    echo "[2/4] Scheduled tasks..."
    TASK_COUNT=$(echo "$TASK_JSON" | python3 -c "import json,sys; print(len(json.load(sys.stdin)))")
    if [ "$TASK_COUNT" -gt 0 ]; then
        echo "$TASK_JSON" | python3 -c "
import json, sys, os, subprocess
tasks = json.load(sys.stdin)
for name, info in tasks.items():
    label = info.get('label', '')
    plist = info.get('plist', '')
    if label:
        subprocess.run(['launchctl', 'bootout', f'gui/{os.getuid()}/{label}'],
                       capture_output=True)
        subprocess.run(['launchctl', 'bootout', label], capture_output=True)
    if plist and os.path.exists(plist):
        os.remove(plist)
    print(f'      [✓] {name} — unloaded and removed')
"
        echo -e "      ${GREEN}Removed $TASK_COUNT task(s).${NC}"
    else
        # Fallback: scan filesystem for plist files
        PLIST_COUNT=$(ls "$HOME/Library/LaunchAgents/com.git-weekly-automation."*.plist 2>/dev/null | wc -l | tr -d ' ')
        if [ "$PLIST_COUNT" -gt 0 ] 2>/dev/null; then
            for plist in "$HOME/Library/LaunchAgents/com.git-weekly-automation."*.plist; do
                [ -f "$plist" ] || continue
                label="com.git-weekly-automation.$(basename "$plist" .plist | sed 's/com.git-weekly-automation.//')"
                launchctl bootout "gui/$(id -u)/$label" 2>/dev/null || launchctl bootout "$label" 2>/dev/null || true
                rm -f "$plist"
            done
            echo -e "      ${GREEN}Removed $PLIST_COUNT task(s) (filesystem scan).${NC}"
        else
            echo "       No tasks found. Skipped."
        fi
    fi

    # --- 3. Remove data ---
    echo "[3/4] Data files..."
    if [ -d "$PROJECT_DIR/data" ] && [ "$(ls -A "$PROJECT_DIR/data" 2>/dev/null)" ]; then
        if [ "$YES_FLAG" = true ]; then
            rm -rf "$PROJECT_DIR/data"
            echo -e "      ${GREEN}Removed.${NC}"
        else
            read -p "      Remove commit logs and state files? [y/N]: " -r CONFIRM
            if [ "$CONFIRM" = "y" ] || [ "$CONFIRM" = "Y" ]; then
                rm -rf "$PROJECT_DIR/data"
                echo -e "      ${GREEN}Removed.${NC}"
            else
                echo "       Skipped."
            fi
        fi
    else
        echo "       No data files. Skipped."
    fi
    # Also remove reports if exists
    if [ -d "$PROJECT_DIR/reports" ] && [ "$(ls -A "$PROJECT_DIR/reports" 2>/dev/null)" ]; then
        if [ "$YES_FLAG" = true ]; then
            rm -rf "$PROJECT_DIR/reports"
            echo -e "      ${GREEN}Removed reports.${NC}"
        else
            read -p "      Remove generated reports? [y/N]: " -r CONFIRM
            if [ "$CONFIRM" = "y" ] || [ "$CONFIRM" = "Y" ]; then
                rm -rf "$PROJECT_DIR/reports"
                echo -e "      ${GREEN}Removed.${NC}"
            else
                echo "       Skipped."
            fi
        fi
    fi

    # --- 4. Unregister from central registry ---
    echo "[4/4] Central registry..."
    python3 -c "
import sys; sys.path.insert(0, '$SCRIPT_DIR')
from registry import unregister_installation
unregister_installation('$PROJECT_DIR')
" 2>/dev/null || true
    echo -e "      ${GREEN}Unregistered.${NC}"

    echo ""
    echo -e "${GREEN}Uninstall complete.${NC}"
    echo ""
    echo "All artifacts have been removed:"
    echo "  • Git global hooksPath restored"
    echo "  • Scheduled tasks unloaded and removed"
    echo "  • Data files handled per your choice"
    echo "  • Central registry entry removed"
    echo ""
    echo "You can now safely delete the project directory:"
    echo "  rm -rf $PROJECT_DIR"
    exit 0
fi

# ======================================================================
# Install (default)
# ======================================================================
if [ "$ACTION" != "install" ]; then
    echo "Usage: $0 [install|uninstall]"
    exit 1
fi

echo "============================================"
echo "  git-weekly-automation — Install Hook"
echo "============================================"
echo ""

# --- Step 1: Check prerequisites ---
echo -n "[1/5] Checking prerequisites... "

COMMAND_FAILURES=()

if ! command -v git &>/dev/null; then
    COMMAND_FAILURES+=("git")
fi
if ! command -v python3 &>/dev/null; then
    COMMAND_FAILURES+=("python3")
fi

if [ ${#COMMAND_FAILURES[@]} -gt 0 ]; then
    echo -e "${RED}MISSING: ${COMMAND_FAILURES[*]}${NC}"
    echo "Please install missing dependencies and re-run this script."
    exit 1
fi

echo -e "${GREEN}OK${NC} (git, python3)"

# --- Step 2: Create directories ---
echo -n "[2/5] Creating project directories... "
mkdir -p "$PROJECT_DIR/data/commits"
mkdir -p "$PROJECT_DIR/data/logs"
mkdir -p "$PROJECT_DIR/reports"
echo -e "${GREEN}OK${NC}"

# --- Step 3: Make hooks executable ---
echo -n "[3/5] Making hook scripts executable... "
for hook in "$HOOKS_DIR"/*; do
    if [ -f "$hook" ]; then
        chmod +x "$hook"
        echo -n "$(basename "$hook") "
    fi
done
echo -e "${GREEN}OK${NC}"

# --- Step 4: Set global hooks path ---
echo -n "[4/5] Configuring git global hooks path... "
# Save original hooksPath for restoration on uninstall
ORIGINAL_HOOKS_PATH="$(git config --global core.hooksPath 2>/dev/null || echo "")"
git config --global core.hooksPath "$HOOKS_PATH_ABS"
echo -e "${GREEN}OK${NC}"
echo "        Hooks path: $HOOKS_PATH_ABS"

# --- Step 5: Verify ---
echo -n "[5/5] Verifying configuration... "
CURRENT_HOOKS_PATH="$(git config --global core.hooksPath 2>/dev/null || echo "")"
if [ "$CURRENT_HOOKS_PATH" = "$HOOKS_PATH_ABS" ]; then
    echo -e "${GREEN}OK${NC}"
else
    echo -e "${RED}FAILED${NC}"
    echo "        Expected: $HOOKS_PATH_ABS"
    echo "        Got:      $CURRENT_HOOKS_PATH"
    exit 1
fi

# --- Step 6: Register in central registry ---
echo -n "[6/6] Registering in central registry... "
INSTALL_METHOD="manual"
if [ -n "${npm_package_name:-}" ]; then
    INSTALL_METHOD="npm-global"
elif [ -n "${npm_config_local_prefix:-}" ]; then
    INSTALL_METHOD="npm-local"
fi
ORIGINAL_HOOKS_PATH_JSON="null"
if [ -n "${ORIGINAL_HOOKS_PATH:-}" ]; then
    ORIGINAL_HOOKS_PATH_JSON="\"$ORIGINAL_HOOKS_PATH\""
fi
python3 -c "
import sys; sys.path.insert(0, '$SCRIPT_DIR')
from registry import register_installation
register_installation(
    project_path='$PROJECT_DIR',
    install_method='$INSTALL_METHOD',
    hooks_path_set=True,
    original_hooks_path=$ORIGINAL_HOOKS_PATH_JSON if '$ORIGINAL_HOOKS_PATH' != '' else None,
)
" 2>/dev/null || true
echo -e "${GREEN}OK${NC}"
echo "        Registry: ~/.git-weekly-automation/registry.json"

# --- Summary ---
echo ""
echo -e "${GREEN}============================================${NC}"
echo -e "${GREEN}  Setup complete!${NC}"
echo -e "${GREEN}============================================${NC}"
echo ""
echo "What happens now:"
echo "  • Every git commit you make on this machine will be logged to:"
echo "    $PROJECT_DIR/data/commits/YYYY-WXX.jsonl"
echo ""
echo "  • To generate a weekly report from your commits:"
echo "    python3 $SCRIPT_DIR/generate-weekly-report"
echo ""
echo "  • To schedule automatic weekly reports:"
echo "    $SCRIPT_DIR/schedule add --name weekly-report --schedule 'Fri 17:00' \\"
echo "      --command 'python3 $SCRIPT_DIR/generate-weekly-report'"
echo ""
echo "  • To remove the global hook:"
echo "    $SCRIPT_DIR/setup uninstall"
echo ""
