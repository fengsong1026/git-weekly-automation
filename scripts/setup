#!/usr/bin/env bash
# ============================================================================
# git-weekly-automation setup script
#
# Performs one-time setup:
#   1. Configures git to use this project's hooks globally
#   2. Creates required directories
#   3. Makes hook scripts executable
#   4. Verifies prerequisites
#
# Usage:
#   ./scripts/setup
# ============================================================================

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
HOOKS_DIR="$PROJECT_DIR/hooks"

# Colors for output
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m' # No Color

echo "============================================"
echo "  git-weekly-automation — One-Time Setup"
echo "============================================"
echo ""

# --- Step 1: Check prerequisites ---
echo -n "[1/5] Checking prerequisites... "

COMMAND_FAILURES=()

if ! command -v git &>/dev/null; then
    COMMAND_FAILURES+=("git")
fi
if ! command -v python3 &>/dev/null; then
    COMMAND_FAILURES+=("python3")
fi

if [ ${#COMMAND_FAILURES[@]} -gt 0 ]; then
    echo -e "${RED}MISSING: ${COMMAND_FAILURES[*]}${NC}"
    echo "Please install missing dependencies and re-run this script."
    exit 1
fi

echo -e "${GREEN}OK${NC} (git, python3)"

# --- Step 2: Create directories ---
echo -n "[2/5] Creating project directories... "
mkdir -p "$PROJECT_DIR/data/commits"
mkdir -p "$PROJECT_DIR/data/logs"
mkdir -p "$PROJECT_DIR/reports"
echo -e "${GREEN}OK${NC}"

# --- Step 3: Make hooks executable ---
echo -n "[3/5] Making hook scripts executable... "
for hook in "$HOOKS_DIR"/*; do
    if [ -f "$hook" ]; then
        chmod +x "$hook"
        echo -n "$(basename "$hook") "
    fi
done
echo -e "${GREEN}OK${NC}"

# --- Step 4: Set global hooks path ---
echo -n "[4/5] Configuring git global hooks path... "
HOOKS_PATH_ABS="$(cd "$HOOKS_DIR" && pwd)"
git config --global core.hooksPath "$HOOKS_PATH_ABS"
echo -e "${GREEN}OK${NC}"
echo "        Hooks path: $HOOKS_PATH_ABS"

# --- Step 5: Verify ---
echo -n "[5/5] Verifying configuration... "
CURRENT_HOOKS_PATH="$(git config --global core.hooksPath 2>/dev/null || echo "")"
if [ "$CURRENT_HOOKS_PATH" = "$HOOKS_PATH_ABS" ]; then
    echo -e "${GREEN}OK${NC}"
else
    echo -e "${RED}FAILED${NC}"
    echo "        Expected: $HOOKS_PATH_ABS"
    echo "        Got:      $CURRENT_HOOKS_PATH"
    exit 1
fi

# --- Summary ---
echo ""
echo -e "${GREEN}============================================${NC}"
echo -e "${GREEN}  Setup complete!${NC}"
echo -e "${GREEN}============================================${NC}"
echo ""
echo "What happens now:"
echo "  • Every git commit you make on this machine will be logged to:"
echo "    $PROJECT_DIR/data/commits/YYYY-WXX.jsonl"
echo ""
echo "  • To generate a weekly report from your commits:"
echo "    python3 $SCRIPT_DIR/generate-weekly-report"
echo ""
echo "  • To schedule automatic weekly reports (every Friday at 5pm):"
echo "    $SCRIPT_DIR/schedule add --name weekly-report --schedule 'Fri 17:00' \\"
echo "      --command 'python3 $SCRIPT_DIR/generate-weekly-report'"
echo ""
echo "  • To undo this setup (restore git defaults):"
echo "    git config --global --unset core.hooksPath"
echo ""
