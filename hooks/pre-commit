#!/usr/bin/env bash
# ============================================================================
# git-weekly-automation — pre-commit hook
#
# Runs the project test suite before every commit.
# A failing test blocks the commit.
#
# Skip with: SKIP_TESTS=1 git commit -m "..."
# ============================================================================

set -euo pipefail

# Allow opt-out via environment variable
if [ "${SKIP_TESTS:-0}" = "1" ]; then
    exit 0
fi

HOOK_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(cd "$HOOK_DIR/.." 2>/dev/null && pwd || echo "")"

# Guard: project deleted
if [ -z "$PROJECT_DIR" ] || [ ! -d "$PROJECT_DIR" ]; then
    exit 0
fi

echo "============================================"
echo "  Running test suite..."
echo "============================================"

cd "$PROJECT_DIR"
python3 tests/run_all.py

echo ""
echo "All tests passed."
